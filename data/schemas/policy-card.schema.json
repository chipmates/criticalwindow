    },
    "body": {
      "type": "string",
      "pattern": "^strings:[a-z][a-zA-Z0-9]*(?:\\.[a-zA-Z0-9]+)+$"
    },
    "cost": {
      "type": "object",
      "properties": {
        "politicalCapital": {
