{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "$schema": {
      "type": "string"
    },
    "id": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9_]*$"
    },
    "title": {
      "type": "string",
      "pattern": "^strings:[a-z][a-zA-Z0-9]*(?:\\.[a-zA-Z0-9]+)+$"
    },
    "body": {
      "type": "string",
      "pattern": "^strings:[a-z][a-zA-Z0-9]*(?:\\.[a-zA-Z0-9]+)+$"
    },
    "trigger": {
      "type": "object",
      "properties": {
        "era": {
          "type": "string",
          "enum": [
            "early",
            "mid",
            "late"
          ]
        },
        "turnMin": {
          "type": "integer",
          "minimum": 1,
          "maximum": 64
        },
        "turnMax": {
          "type": "integer",
          "minimum": 1,
          "maximum": 64
        },
        "weight": {
          "type": "integer",
          "minimum": 1,
          "maximum": 10
        },
        "conditions": {
          "type": "object",
          "properties": {
            "rivalPosture": {
              "type": "string",
              "enum": [
                "race",
                "mirror",
                "cautious"
              ]
            },
            "flagsAll": {
              "minItems": 1,
              "type": "array",
              "items": {
                "type": "string",
                "pattern": "^[a-z][a-zA-Z0-9]*$"
              }
            },
            "flagsNone": {
              "minItems": 1,
              "type": "array",
              "items": {
                "type": "string",
                "pattern": "^[a-z][a-zA-Z0-9]*$"
              }
            },
            "resourceMin": {
              "type": "object",
              "properties": {
                "compute": {
                  "type": "integer",
                  "minimum": 0,
                  "maximum": 1000
                },
                "energy": {
                  "type": "integer",
                  "minimum": 0,
                  "maximum": 1000
                },
                "talent": {
                  "type": "integer",
                  "minimum": 0,
                  "maximum": 1000
                },
                "capital": {
                  "type": "integer",
                  "minimum": 0,
                  "maximum": 1000
                },
                "publicTrust": {
                  "type": "integer",
                  "minimum": 0,
                  "maximum": 1000
                },
                "politicalCapital": {
                  "type": "integer",
                  "minimum": 0,
                  "maximum": 1000
                },
                "capability": {
                  "type": "integer",
                  "minimum": 0,
                  "maximum": 1000
                },
                "safetyInsight": {
                  "type": "integer",
                  "minimum": 0,
                  "maximum": 1000
                }
              },
              "additionalProperties": false
            },
            "resourceMax": {
              "type": "object",
              "properties": {
                "compute": {
                  "type": "integer",
                  "minimum": 0,
                  "maximum": 1000
                },
                "energy": {
                  "type": "integer",
                  "minimum": 0,
                  "maximum": 1000
                },
                "talent": {
                  "type": "integer",
                  "minimum": 0,
                  "maximum": 1000
                },
                "capital": {
                  "type": "integer",
                  "minimum": 0,
                  "maximum": 1000
                },
                "publicTrust": {
                  "type": "integer",
                  "minimum": 0,
                  "maximum": 1000
                },
                "politicalCapital": {
                  "type": "integer",
                  "minimum": 0,
                  "maximum": 1000
                },
                "capability": {
                  "type": "integer",
                  "minimum": 0,
                  "maximum": 1000
                },
                "safetyInsight": {
                  "type": "integer",
                  "minimum": 0,
                  "maximum": 1000
                }
              },
              "additionalProperties": false
            }
          },
          "additionalProperties": false
        }
      },
      "required": [
        "weight"
      ],
      "additionalProperties": false
    },
    "choices": {
      "minItems": 1,
      "maxItems": 4,
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "label": {
            "type": "string",
            "pattern": "^strings:[a-z][a-zA-Z0-9]*(?:\\.[a-zA-Z0-9]+)+$"
          },
          "effects": {
            "type": "object",
            "properties": {
              "compute": {
                "type": "integer",
                "minimum": -1000,
                "maximum": 1000
              },
              "energy": {
                "type": "integer",
                "minimum": -1000,
                "maximum": 1000
              },
              "talent": {
                "type": "integer",
                "minimum": -1000,
                "maximum": 1000
              },
              "capital": {
                "type": "integer",
                "minimum": -1000,
                "maximum": 1000
              },
              "publicTrust": {
                "type": "integer",
                "minimum": -1000,
                "maximum": 1000
              },
              "politicalCapital": {
                "type": "integer",
                "minimum": -1000,
                "maximum": 1000
              },
              "capability": {
                "type": "integer",
                "minimum": -1000,
                "maximum": 1000
              },
              "safetyInsight": {
                "type": "integer",
                "minimum": -1000,
                "maximum": 1000
              },
              "society.jobDisplacement": {
                "type": "integer",
                "minimum": -1000,
                "maximum": 1000
              },
              "society.unrest": {
                "type": "integer",
                "minimum": -1000,
                "maximum": 1000
              },
              "rival.trust": {
                "type": "integer",
                "minimum": -1000,
                "maximum": 1000
              },
              "rival.capability": {
                "type": "integer",
                "minimum": -1000,
                "maximum": 1000
              },
              "rival.substitution": {
                "type": "integer",
                "minimum": -1000,
                "maximum": 1000
              },
              "hidden.trueAlignment": {
                "type": "integer",
                "minimum": -1000,
                "maximum": 1000
              },
              "hidden.agencyErosion": {
                "type": "integer",
                "minimum": -1000,
                "maximum": 1000
              },
              "flags": {
                "minItems": 1,
                "type": "array",
                "items": {
                  "type": "string",
                  "pattern": "^[a-z][a-zA-Z0-9]*$"
                }
              },
              "clearFlags": {
                "minItems": 1,
                "type": "array",
                "items": {
                  "type": "string",
                  "pattern": "^[a-z][a-zA-Z0-9]*$"
                }
              }
            },
            "additionalProperties": false
          },
          "delayedEffects": {
            "minItems": 1,
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "inTurns": {
                  "type": "integer",
                  "minimum": 1,
                  "maximum": 16
                },
                "effects": {
                  "type": "object",
                  "properties": {
                    "compute": {
                      "type": "integer",
                      "minimum": -1000,
                      "maximum": 1000
                    },
                    "energy": {
                      "type": "integer",
                      "minimum": -1000,
                      "maximum": 1000
                    },
                    "talent": {
                      "type": "integer",
                      "minimum": -1000,
                      "maximum": 1000
                    },
                    "capital": {
                      "type": "integer",
                      "minimum": -1000,
                      "maximum": 1000
                    },
                    "publicTrust": {
                      "type": "integer",
                      "minimum": -1000,
                      "maximum": 1000
                    },
                    "politicalCapital": {
                      "type": "integer",
                      "minimum": -1000,
                      "maximum": 1000
                    },
                    "capability": {
                      "type": "integer",
                      "minimum": -1000,
                      "maximum": 1000
                    },
                    "safetyInsight": {
                      "type": "integer",
                      "minimum": -1000,
                      "maximum": 1000
                    },
                    "society.jobDisplacement": {
                      "type": "integer",
                      "minimum": -1000,
                      "maximum": 1000
                    },
                    "society.unrest": {
                      "type": "integer",
                      "minimum": -1000,
                      "maximum": 1000
                    },
                    "rival.trust": {
                      "type": "integer",
                      "minimum": -1000,
                      "maximum": 1000
                    },
                    "rival.capability": {
                      "type": "integer",
                      "minimum": -1000,
                      "maximum": 1000
                    },
                    "rival.substitution": {
                      "type": "integer",
                      "minimum": -1000,
                      "maximum": 1000
                    },
                    "hidden.trueAlignment": {
                      "type": "integer",
                      "minimum": -1000,
                      "maximum": 1000
                    },
                    "hidden.agencyErosion": {
                      "type": "integer",
                      "minimum": -1000,
                      "maximum": 1000
                    },
                    "flags": {
                      "minItems": 1,
                      "type": "array",
                      "items": {
                        "type": "string",
                        "pattern": "^[a-z][a-zA-Z0-9]*$"
                      }
                    },
                    "clearFlags": {
                      "minItems": 1,
                      "type": "array",
                      "items": {
                        "type": "string",
                        "pattern": "^[a-z][a-zA-Z0-9]*$"
                      }
                    }
                  },
                  "additionalProperties": false
                }
              },
              "required": [
                "inTurns",
                "effects"
              ],
              "additionalProperties": false
            }
          }
        },
        "required": [
          "label"
        ],
        "additionalProperties": false
      }
    },
    "repeatable": {
      "type": "boolean"
    },
    "sourceIds": {
      "minItems": 1,
      "type": "array",
      "items": {
        "anyOf": [
          {
            "type": "string",
            "pattern": "^SRC-[A-Z0-9]+(?:-[A-Z0-9]+)*$"
          },
          {
            "type": "string",
            "const": "TODO-SOURCE"
          }
        ]
      }
    },
    "tags": {
      "minItems": 1,
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^[a-z][a-z0-9-]*$"
      }
    }
  },
  "required": [
    "id",
    "title",
    "body",
    "trigger",
    "choices",
    "sourceIds",
    "tags"
  ],
  "additionalProperties": false
}
