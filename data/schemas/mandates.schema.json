{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "$schema": {
      "type": "string"
    },
    "perEraDraw": {
      "type": "integer",
      "minimum": 1,
      "maximum": 2
    },
    "mandates": {
      "minItems": 1,
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^[a-z][a-z0-9_]*$"
          },
          "title": {
            "type": "string",
            "pattern": "^strings:[a-z][a-zA-Z0-9]*(?:\\.[a-zA-Z0-9]+)+$"
          },
          "body": {
            "type": "string",
            "pattern": "^strings:[a-z][a-zA-Z0-9]*(?:\\.[a-zA-Z0-9]+)+$"
          },
          "era": {
            "type": "string",
            "enum": [
              "early",
              "mid",
              "late"
            ]
          },
          "goal": {
            "type": "object",
            "properties": {
              "target": {
                "type": "string",
                "enum": [
                  "compute",
                  "energy",
                  "talent",
                  "capital",
                  "publicTrust",
                  "politicalCapital",
                  "capability",
                  "safetyInsight",
                  "society.jobDisplacement",
                  "society.unrest",
                  "rival.trust",
                  "rival.capability",
                  "rival.substitution",
                  "hidden.trueAlignment",
                  "hidden.agencyErosion"
                ]
              },
              "comparator": {
                "type": "string",
                "enum": [
                  "<=",
                  ">="
                ]
              },
              "value": {
                "type": "integer",
                "minimum": 0,
                "maximum": 1000
              },
              "byTurnOffset": {
                "type": "integer",
                "minimum": 1,
                "maximum": 15
              }
            },
            "required": [
              "target",
              "comparator",
              "value",
              "byTurnOffset"
            ],
            "additionalProperties": false
          },
          "rewardPoliticalCapital": {
            "type": "integer",
            "minimum": 0,
            "maximum": 1000
          },
          "penaltyOnLapse": {
            "type": "object",
            "properties": {
              "compute": {
                "type": "integer",
                "minimum": -1000,
                "maximum": 1000
              },
              "energy": {
                "type": "integer",
                "minimum": -1000,
                "maximum": 1000
              },
              "talent": {
                "type": "integer",
                "minimum": -1000,
                "maximum": 1000
              },
              "capital": {
                "type": "integer",
                "minimum": -1000,
                "maximum": 1000
              },
              "publicTrust": {
                "type": "integer",
                "minimum": -1000,
                "maximum": 1000
              },
              "politicalCapital": {
                "type": "integer",
                "minimum": -1000,
                "maximum": 1000
              },
              "capability": {
                "type": "integer",
                "minimum": -1000,
                "maximum": 1000
              },
              "safetyInsight": {
                "type": "integer",
                "minimum": -1000,
                "maximum": 1000
              },
              "society.jobDisplacement": {
                "type": "integer",
                "minimum": -1000,
                "maximum": 1000
              },
              "society.unrest": {
                "type": "integer",
                "minimum": -1000,
                "maximum": 1000
              },
              "rival.trust": {
                "type": "integer",
                "minimum": -1000,
                "maximum": 1000
              },
              "rival.capability": {
                "type": "integer",
                "minimum": -1000,
                "maximum": 1000
              },
              "rival.substitution": {
                "type": "integer",
                "minimum": -1000,
                "maximum": 1000
              },
              "hidden.trueAlignment": {
                "type": "integer",
                "minimum": -1000,
                "maximum": 1000
              },
              "hidden.agencyErosion": {
                "type": "integer",
                "minimum": -1000,
                "maximum": 1000
              },
              "flags": {
                "minItems": 1,
                "type": "array",
                "items": {
                  "type": "string",
                  "pattern": "^[a-z][a-zA-Z0-9]*$"
                }
              },
              "clearFlags": {
                "minItems": 1,
                "type": "array",
                "items": {
                  "type": "string",
                  "pattern": "^[a-z][a-zA-Z0-9]*$"
                }
              }
            },
            "additionalProperties": false
          },
          "sourceIds": {
            "minItems": 1,
            "type": "array",
            "items": {
              "anyOf": [
                {
                  "type": "string",
                  "pattern": "^SRC-[A-Z0-9]+(?:-[A-Z0-9]+)*$"
                },
                {
                  "type": "string",
                  "const": "TODO-SOURCE"
                }
              ]
            }
          },
          "claimIds": {
            "minItems": 1,
            "type": "array",
            "items": {
              "type": "string",
              "pattern": "^SRC-[A-Z0-9]+(?:-[A-Z0-9]+)*#\\d+$"
            }
          }
        },
        "required": [
          "id",
          "title",
          "body",
          "era",
          "goal",
          "rewardPoliticalCapital",
          "sourceIds"
        ],
        "additionalProperties": false
      }
    },
    "sourceIds": {
      "minItems": 1,
      "type": "array",
      "items": {
        "anyOf": [
          {
            "type": "string",
            "pattern": "^SRC-[A-Z0-9]+(?:-[A-Z0-9]+)*$"
          },
          {
            "type": "string",
            "const": "TODO-SOURCE"
          }
        ]
      }
    }
  },
  "required": [
    "perEraDraw",
    "mandates",
    "sourceIds"
  ],
  "additionalProperties": false
}
