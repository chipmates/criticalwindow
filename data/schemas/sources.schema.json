{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "$schema": {
      "type": "string"
    },
    "sources": {
      "minItems": 1,
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^SRC-[A-Z0-9]+(?:-[A-Z0-9]+)*$"
          },
          "title": {
            "type": "string",
            "minLength": 1
          },
          "authors": {
            "type": "string"
          },
          "org": {
            "type": "string"
          },
          "year": {
            "type": "integer",
            "minimum": 1900,
            "maximum": 2100
          },
          "url": {
            "type": "string",
            "format": "uri"
          },
          "type": {
            "type": "string",
            "enum": [
              "paper",
              "report",
              "book",
              "dataset",
              "web",
              "design"
            ]
          },
          "tags": {
            "type": "array",
            "items": {
              "type": "string",
              "pattern": "^[a-z][a-z0-9-]*$"
            }
          },
          "status": {
            "type": "string",
            "enum": [
              "verified",
              "flagged",
              "book",
              "pending"
            ]
          },
          "gameUse": {
            "type": "string"
          },
          "note": {
            "type": "string"
          }
        },
        "required": [
          "id",
          "title",
          "type",
          "status"
        ],
        "additionalProperties": false
      }
    }
  },
  "required": [
    "sources"
  ],
  "additionalProperties": false
}
