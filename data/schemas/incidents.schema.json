{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "$schema": {
      "type": "string"
    },
    "riskFormula": {
      "type": "object",
      "properties": {
        "pressureAllocationPct": {
          "type": "object",
          "properties": {
            "value": {
              "type": "integer",
              "minimum": -1000,
              "maximum": 1000
            },
            "sourceIds": {
              "minItems": 1,
              "type": "array",
              "items": {
                "anyOf": [
                  {
                    "type": "string",
                    "pattern": "^SRC-[A-Z0-9]+(?:-[A-Z0-9]+)*$"
                  },
                  {
                    "type": "string",
                    "const": "TODO-SOURCE"
                  }
                ]
              }
            },
            "note": {
              "type": "string"
            }
          },
          "required": [
            "value",
            "sourceIds"
          ],
          "additionalProperties": false
        },
        "pressureRivalRacePct": {
          "type": "object",
          "properties": {
            "value": {
              "type": "integer",
              "minimum": -1000,
              "maximum": 1000
            },
            "sourceIds": {
              "minItems": 1,
              "type": "array",
              "items": {
                "anyOf": [
                  {
                    "type": "string",
                    "pattern": "^SRC-[A-Z0-9]+(?:-[A-Z0-9]+)*$"
                  },
                  {
                    "type": "string",
                    "const": "TODO-SOURCE"
                  }
                ]
              }
            },
            "note": {
              "type": "string"
            }
          },
          "required": [
            "value",
            "sourceIds"
          ],
          "additionalProperties": false
        }
      },
      "required": [
        "pressureAllocationPct",
        "pressureRivalRacePct"
      ],
      "additionalProperties": false
    },
    "safetyInsightDamageReductionMaxPerMille": {
      "type": "object",
      "properties": {
        "value": {
          "type": "integer",
          "minimum": -1000,
          "maximum": 1000
        },
        "sourceIds": {
          "minItems": 1,
          "type": "array",
          "items": {
            "anyOf": [
              {
                "type": "string",
                "pattern": "^SRC-[A-Z0-9]+(?:-[A-Z0-9]+)*$"
              },
              {
                "type": "string",
                "const": "TODO-SOURCE"
              }
            ]
          }
        },
        "note": {
          "type": "string"
        }
      },
      "required": [
        "value",
        "sourceIds"
      ],
      "additionalProperties": false
    },
    "rungs": {
      "minItems": 1,
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^[a-z][a-z0-9_]*$"
          },
          "ladder": {
            "type": "integer",
            "minimum": 0,
            "maximum": 3
          },
          "title": {
            "type": "string",
            "pattern": "^strings:[a-z][a-zA-Z0-9]*(?:\\.[a-zA-Z0-9]+)+$"
          },
          "body": {
            "type": "string",
            "pattern": "^strings:[a-z][a-zA-Z0-9]*(?:\\.[a-zA-Z0-9]+)+$"
          },
          "threshold": {
            "type": "integer",
            "minimum": 0,
            "maximum": 1000
          },
          "baseDamage": {
            "type": "object",
            "properties": {
              "compute": {
                "type": "integer",
                "minimum": -1000,
                "maximum": 1000
              },
              "energy": {
                "type": "integer",
                "minimum": -1000,
                "maximum": 1000
              },
              "talent": {
                "type": "integer",
                "minimum": -1000,
                "maximum": 1000
              },
              "capital": {
                "type": "integer",
                "minimum": -1000,
                "maximum": 1000
              },
              "publicTrust": {
                "type": "integer",
                "minimum": -1000,
                "maximum": 1000
              },
              "politicalCapital": {
                "type": "integer",
                "minimum": -1000,
                "maximum": 1000
              },
              "capability": {
                "type": "integer",
                "minimum": -1000,
                "maximum": 1000
              },
              "safetyInsight": {
                "type": "integer",
                "minimum": -1000,
                "maximum": 1000
              },
              "society.jobDisplacement": {
                "type": "integer",
                "minimum": -1000,
                "maximum": 1000
              },
              "society.unrest": {
                "type": "integer",
                "minimum": -1000,
                "maximum": 1000
              },
              "substitution": {
                "type": "integer",
                "minimum": -1000,
                "maximum": 1000
              },
              "rival.trust": {
                "type": "integer",
                "minimum": -1000,
                "maximum": 1000
              },
              "rival.capability": {
                "type": "integer",
                "minimum": -1000,
                "maximum": 1000
              },
              "rival.substitution": {
                "type": "integer",
                "minimum": -1000,
                "maximum": 1000
              },
              "hidden.trueAlignment": {
                "type": "integer",
                "minimum": -1000,
                "maximum": 1000
              },
              "hidden.agencyErosion": {
                "type": "integer",
                "minimum": -1000,
                "maximum": 1000
              },
              "flags": {
                "minItems": 1,
                "type": "array",
                "items": {
                  "type": "string",
                  "pattern": "^[a-z][a-zA-Z0-9]*$"
                }
              },
              "clearFlags": {
                "minItems": 1,
                "type": "array",
                "items": {
                  "type": "string",
                  "pattern": "^[a-z][a-zA-Z0-9]*$"
                }
              }
            },
            "additionalProperties": false
          },
          "forcedPause": {
            "type": "boolean"
          },
          "cooldownTurns": {
            "type": "integer",
            "minimum": 1,
            "maximum": 16
          },
          "catastropheBelowTrueAlignment": {
            "type": "integer",
            "minimum": 0,
            "maximum": 1000
          },
          "sourceIds": {
            "minItems": 1,
            "type": "array",
            "items": {
              "anyOf": [
                {
                  "type": "string",
                  "pattern": "^SRC-[A-Z0-9]+(?:-[A-Z0-9]+)*$"
                },
                {
                  "type": "string",
                  "const": "TODO-SOURCE"
                }
              ]
            }
          },
          "claimIds": {
            "minItems": 1,
            "type": "array",
            "items": {
              "type": "string",
              "pattern": "^SRC-[A-Z0-9]+(?:-[A-Z0-9]+)*#\\d+$"
            }
          }
        },
        "required": [
          "id",
          "ladder",
          "title",
          "body",
          "threshold",
          "baseDamage",
          "forcedPause",
          "cooldownTurns",
          "sourceIds"
        ],
        "additionalProperties": false
      }
    },
    "sourceIds": {
      "minItems": 1,
      "type": "array",
      "items": {
        "anyOf": [
          {
            "type": "string",
            "pattern": "^SRC-[A-Z0-9]+(?:-[A-Z0-9]+)*$"
          },
          {
            "type": "string",
            "const": "TODO-SOURCE"
          }
        ]
      }
    }
  },
  "required": [
    "riskFormula",
    "safetyInsightDamageReductionMaxPerMille",
    "rungs",
    "sourceIds"
  ],
  "additionalProperties": false
}
